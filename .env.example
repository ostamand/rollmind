# Inference Mode: 'local' (Local GPU) or 'vertex' (Google Cloud)
INFERENCE_MODE=local

# Google Cloud / Vertex AI Configuration
GOOGLE_CLOUD_PROJECT="your-project-id"
GOOGLE_CLOUD_LOCATION="us-central1"
VERTEX_ENDPOINT_ID="your-endpoint-id"

# Local Model Configuration
MODEL_ID=google/gemma-7b-it
ADAPTER_PATH=./out/step2/your-best-checkpoint
ADAPTER_BASE_DIR=../../out/step2/

# Memory Management (Local only)
MAX_GPU_MEMORY=7.5GiB
OFFLOAD_TIMEOUT_MINUTES=10

# API Settings
HOST=0.0.0.0
PORT=8000

# UI Settings (Next.js)
NEXT_PUBLIC_HIDE_CONFIG=false
